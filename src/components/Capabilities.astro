---
const caps = [
  { t: 'Email', d: 'Reply drafts, summaries, analyses, and reports — in your voice. You send.' },
  { t: 'Calendar', d: 'Proposes meetings and places holds; with your approval, invites the other people — from her own identity.' },
  { t: 'Files', d: 'Reads your company documents to inform a draft, and (with your approval) shares a file.' },
];
---
<section id="handles" class="bg-white border-y border-black/10">
  <div class="mx-auto max-w-[1100px] px-6 py-20">
    <h2 class="font-[var(--font-display)] text-4xl">What Nora handles</h2>
    <p class="mt-3 text-ink/70">Every action passes the same gate: <strong>propose → you approve → Nora acts as herself.</strong></p>
    <div class="mt-10 grid gap-8 md:grid-cols-3">
      {caps.map((c) => (
        <div class="rounded-2xl border border-black/10 p-6">
          <h3 class="text-xl font-semibold">{c.t}</h3>
          <p class="mt-2 text-ink/75">{c.d}</p>
          <p class="mt-4 text-xs font-mono text-[var(--color-approve)]">propose → approve → act</p>
        </div>
      ))}
    </div>
  </div>
</section>
