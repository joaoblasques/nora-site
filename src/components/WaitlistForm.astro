---
// Buttondown's official embed form. The form POSTs to Buttondown, which handles the
// anti-spam verification + double opt-in (a confirmation email). target/onsubmit open the
// confirm step in a popup so the visitor stays on the landing page. Styled to match the site.
const username = 'nora-bennett';
const action = `https://buttondown.com/api/emails/embed-subscribe/${username}`;
---
<form
  action={action}
  method="post"
  target="popupwindow"
  onsubmit={`window.open('https://buttondown.com/${username}', 'popupwindow')`}
  class="mt-8 flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
>
  <label for="wl-email" class="sr-only">Email address</label>
  <input
    id="wl-email"
    type="email"
    name="email"
    required
    placeholder="you@company.com"
    class="flex-1 rounded-full border border-black/15 px-5 py-3 focus:outline-none focus:border-[var(--color-approve)]"
  />
  <input type="hidden" name="tag" value="website-waitlist" />
  <button
    type="submit"
    class="rounded-full bg-[var(--color-approve)] text-white px-6 py-3 font-medium hover:opacity-90"
  >Join</button>
</form>
<p class="mt-3 text-center text-sm text-ink/60">
  Double opt-in — we'll send a quick confirmation email, then your early-access invite when it's ready.
</p>
