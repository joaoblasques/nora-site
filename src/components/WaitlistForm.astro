---
const endpoint = import.meta.env.PUBLIC_WAITLIST_ENDPOINT ?? 'PLACEHOLDER';
---
<form id="waitlist-form" data-endpoint={endpoint} class="mt-8 flex flex-col sm:flex-row gap-3 max-w-md mx-auto" novalidate>
  <label for="wl-email" class="sr-only">Email address</label>
  <input id="wl-email" name="email" type="email" required placeholder="you@company.com"
    class="flex-1 rounded-full border border-black/15 px-5 py-3 focus:outline-none focus:border-[var(--color-approve)]" />
  <button type="submit" class="rounded-full bg-[var(--color-approve)] text-white px-6 py-3 font-medium hover:opacity-90 disabled:opacity-50">Join</button>
</form>
<p id="wl-msg" role="status" aria-live="polite" class="mt-3 text-center text-sm h-5"></p>
<script>
  import { submitWaitlist } from '../lib/waitlist';
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const msg = document.getElementById('wl-msg');
  const btn = form?.querySelector('button');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.querySelector('#wl-email') as HTMLInputElement).value;
    const endpoint = form.dataset.endpoint || 'PLACEHOLDER';
    if (btn) btn.disabled = true;
    const r = await submitWaitlist(email, { endpoint });
    if (msg) { msg.textContent = r.message; msg.style.color = r.ok ? 'var(--color-approve)' : '#b00020'; }
    if (btn) btn.disabled = false;
    if (r.ok) form.reset();
  });
</script>
